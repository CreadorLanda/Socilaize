# Copy to .env and fill in. The .env file is loaded automatically in dev.

APP_ENV=dev
HTTP_ADDR=:8080

# ── Postgres ─────────────────────────────────────────────────────────────────
#
# Use the Supabase TRANSACTION-MODE pooler URL (port 6543), NOT the direct
# 5432 connection — direct connections exhaust quickly.
#
# Get it from: Supabase dashboard → Project Settings → Database
#              → Connection string → URI (under "Connection pooler", "Transaction")
#
# Format:
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#
POSTGRES_URL=postgresql://postgres.<project>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require

# Offline-only fallback (uncomment + run `make docker-up-local`):
# POSTGRES_URL=postgres://socialize:socialize@localhost:5432/socialize?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
#
# Pick ONE source:
#
# A) Upstash (free tier, recommended for early stages) — TCP URL, always TLS:
#    Get it from: console.upstash.com → Database → Connect → "Redis CLI" line
#                 (use the rediss:// form, not the REST URL).
REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379
#
# B) Self-hosted on the same VPS:
# REDIS_URL=redis://localhost:6379/0
#
# C) Local Docker for offline dev (`make docker-up`):
# REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────────────────────────────
#
# 32+ bytes of random secret. Generate with:
#   openssl rand -base64 48
#
JWT_SECRET=replace-me-with-at-least-32-bytes-of-random-secret-data
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
