# Copy to .env and adjust. .env is loaded automatically in dev.

APP_ENV=dev
HTTP_ADDR=:8080

POSTGRES_URL=postgres://socialize:socialize@localhost:5432/socialize?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# 32+ bytes. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-at-least-32-bytes-of-random-secret-data
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
